rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'maxwellvenere68@gmail.com';
    }

    match /users/{userId} {
      allow read: if isAdmin() || (request.auth != null && request.auth.uid == userId);
      allow write: if request.auth != null && request.auth.uid == userId;

      match /{subcollection=**} {
        allow read: if isAdmin() || (request.auth != null && request.auth.uid == userId);
        allow write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // collectionGroup query on exerciseSessions (used by admin stats)
    match /{path=**}/exerciseSessions/{sessionId} {
      allow read: if isAdmin();
    }

    match /announcements/{announcementId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Admin role documents — readable/writable only by the admin themselves
    match /adminRoles/{uid} {
      allow read, write: if isAdmin() && request.auth.uid == uid;
    }

    // Curriculum content (legacy 4ème) — readable by authenticated users, writable only by admin
    match /curriculum/{dayKey} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Multi-level content (old structure, kept for backwards compat)
    match /levels/{niveauId}/days/{dayKey} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // New unified contenus structure — jours and semaines per niveau
    match /contenus/{niveauId}/jours/{jourId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /contenus/{niveauId}/semaines/{semaineId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Challenges — readable by all authenticated users, writable by admin
    match /challenges/{id} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Badges — global list readable by admin, user-specific badges in users subcollection
    match /badges/{id} {
      allow read, write: if isAdmin();
    }

    // Error logs & backup events — admin only
    match /errorLogs/{id} {
      allow read, write: if isAdmin();
    }
  }
}
