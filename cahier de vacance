  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; }

    :root {
      --indigo: #4338CA;
      --indigo-dark: #1E1B4B;
      --indigo-light: #EEF2FF;
      --radius: 14px;
      --safe-bottom: env(safe-area-inset-bottom, 0px);
    }

    body {
      font-family: -apple-system, 'SF Pro Display', 'Segoe UI', sans-serif;
      background: #F1F5F9;
      color: #1E293B;
      min-height: 100dvh;
      overflow-x: hidden;
    }

    /* ── HEADER ── */
    .header {
      background: linear-gradient(160deg, #1E1B4B 0%, #3730A3 60%, #4338CA 100%);
      color: white;
      padding: 56px 20px 20px;
      position: relative;
      overflow: hidden;
    }
    .header::before {
      content: '';
      position: absolute;
      top: -40px; right: -40px;
      width: 180px; height: 180px;
      border-radius: 50%;
      background: rgba(255,255,255,0.05);
    }
    .header::after {
      content: '';
      position: absolute;
      bottom: -30px; left: -20px;
      width: 120px; height: 120px;
      border-radius: 50%;
      background: rgba(255,255,255,0.04);
    }
    .app-label {
      font-size: 10px;
      letter-spacing: 3px;
      text-transform: uppercase;
      opacity: 0.6;
      margin-bottom: 4px;
    }
    .app-title {
      font-size: 28px;
      font-weight: 900;
      letter-spacing: -1px;
      margin-bottom: 2px;
    }
    .app-sub {
      font-size: 13px;
      opacity: 0.65;
      margin-bottom: 18px;
    }
    .progress-wrap { margin-bottom: 6px; }
    .progress-bar-bg {
      background: rgba(255,255,255,0.18);
      border-radius: 99px;
      height: 7px;
      overflow: hidden;
    }
    .progress-bar-fill {
      background: linear-gradient(90deg, #A5F3FC, #60A5FA);
      border-radius: 99px;
      height: 7px;
      transition: width 0.5s cubic-bezier(.4,0,.2,1);
    }
    .progress-label {
      font-size: 11px;
      opacity: 0.65;
      margin-top: 5px;
    }

    /* ── WEEK TABS ── */
    .tabs-wrap {
      background: white;
      border-bottom: 1px solid #E2E8F0;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
    }
    .tabs-wrap::-webkit-scrollbar { display: none; }
    .tabs {
      display: flex;
      padding: 0 8px;
      min-width: max-content;
    }
    .tab {
      border: none;
      background: none;
      padding: 10px 14px 8px;
      cursor: pointer;
      border-bottom: 3px solid transparent;
      transition: all 0.2s;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 1px;
      color: #94A3B8;
      position: relative;
    }
    .tab.active { color: var(--week-color); border-bottom-color: var(--week-color); }
    .tab-emoji { font-size: 18px; }
    .tab-num { font-size: 12px; font-weight: 700; }
    .tab-progress { font-size: 10px; opacity: 0.7; }

    /* ── WEEK BANNER ── */
    .week-banner {
      margin: 16px 16px 12px;
      border-radius: var(--radius);
      padding: 14px 18px;
      border: 1.5px solid transparent;
    }
    .week-eyebrow {
      font-size: 10px;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 1.5px;
      margin-bottom: 4px;
    }
    .week-title {
      font-size: 17px;
      font-weight: 800;
      color: #0F172A;
    }

    /* ── DAYS ── */
    .days-list {
      padding: 0 16px;
      display: flex;
      flex-direction: column;
      gap: 10px;
      padding-bottom: calc(90px + var(--safe-bottom));
    }

    .day-card {
      background: white;
      border-radius: var(--radius);
      border: 1.5px solid #E2E8F0;
      overflow: hidden;
      transition: border-color 0.2s, box-shadow 0.2s;
    }
    .day-card.done { opacity: 0.65; }
    .day-card.open { box-shadow: 0 4px 20px rgba(0,0,0,0.08); }

    .day-header {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 14px 16px;
      cursor: pointer;
      user-select: none;
      -webkit-user-select: none;
    }

    .checkbox {
      width: 24px; height: 24px;
      border-radius: 7px;
      border: 2px solid #CBD5E1;
      background: white;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
      cursor: pointer;
      transition: all 0.2s;
      font-size: 13px;
      font-weight: 900;
      color: white;
    }
    .checkbox.checked { border: none; }

    .day-info { flex: 1; min-width: 0; }
    .day-label {
      font-size: 14px;
      font-weight: 700;
      color: #0F172A;
      margin-bottom: 2px;
    }
    .day-label.done-text { text-decoration: line-through; color: #94A3B8; }
    .day-badge {
      display: inline-block;
      font-size: 10px;
      font-weight: 700;
      padding: 2px 8px;
      border-radius: 99px;
      color: white;
      margin-bottom: 3px;
    }
    .day-lecon {
      font-size: 11.5px;
      color: #64748B;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .chevron {
      color: #CBD5E1;
      font-size: 14px;
      transition: transform 0.2s;
      flex-shrink: 0;
    }
    .chevron.open { transform: rotate(180deg); color: #6366F1; }

    /* ── DAY DETAIL ── */
    .day-detail {
      border-top: 1px solid #F1F5F9;
      padding: 16px;
      display: none;
    }
    .day-detail.open { display: block; }

    .detail-section { margin-bottom: 14px; }
    .detail-label {
      font-size: 10px;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 1.5px;
      margin-bottom: 8px;
    }
    .detail-box {
      background: white;
      border-radius: 10px;
      padding: 12px 14px;
      border: 1px solid #F1F5F9;
      font-size: 13px;
      color: #374151;
      line-height: 1.65;
    }
    .exo-row {
      padding: 5px 0;
      border-bottom: 1px solid #F8FAFC;
      font-size: 13px;
      color: #1E293B;
      line-height: 1.5;
    }
    .exo-row:last-child { border: none; }
    .exo-arrow { color: #6366F1; font-weight: 700; margin-right: 4px; }

    .tip-box {
      background: #FFFBEB;
      border: 1.5px solid #FDE68A;
      border-radius: 10px;
      padding: 11px 14px;
      display: flex;
      gap: 10px;
      align-items: flex-start;
      margin-bottom: 14px;
    }
    .tip-icon { font-size: 16px; flex-shrink: 0; }
    .tip-text { font-size: 12.5px; color: #92400E; line-height: 1.6; }

    .done-btn {
      width: 100%;
      padding: 12px;
      border-radius: 10px;
      border: none;
      cursor: pointer;
      font-weight: 700;
      font-size: 14px;
      transition: all 0.2s;
    }

    /* ── BOTTOM NAV ── */
    .bottom-nav {
      position: fixed;
      bottom: 0;
      left: 0; right: 0;
      background: white;
      border-top: 1px solid #E2E8F0;
      display: flex;
      padding: 10px 20px;
      padding-bottom: calc(10px + var(--safe-bottom));
      gap: 10px;
      z-index: 100;
      box-shadow: 0 -4px 20px rgba(0,0,0,0.06);
    }
    .nav-btn {
      flex: 1;
      padding: 11px;
      border-radius: 10px;
      border: 1.5px solid #E2E8F0;
      background: white;
      font-size: 13px;
      font-weight: 700;
      color: #374151;
      cursor: pointer;
      transition: all 0.2s;
    }
    .nav-btn:disabled { opacity: 0.35; cursor: not-allowed; }
    .nav-btn.next {
      background: var(--week-color, #4338CA);
      color: white;
      border: none;
    }

    /* ── INSTALL BANNER ── */
    .install-banner {
      margin: 12px 16px 0;
      background: linear-gradient(135deg, #1E1B4B, #4338CA);
      border-radius: var(--radius);
      padding: 14px 16px;
      display: flex;
      align-items: center;
      gap: 12px;
      color: white;
    }
    .install-icon { font-size: 28px; }
    .install-text { flex: 1; }
    .install-title { font-size: 13px; font-weight: 700; margin-bottom: 2px; }
    .install-sub { font-size: 11px; opacity: 0.75; }
    .install-close {
      background: none; border: none; color: white; opacity: 0.6;
      font-size: 18px; cursor: pointer; padding: 4px;
    }

    /* Animations */
    @keyframes slideDown {
      from { opacity: 0; transform: translateY(-8px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .day-detail.open { animation: slideDown 0.2s ease; }

    /* Confetti effect */
    @keyframes pop { 0%{transform:scale(1)} 50%{transform:scale(1.15)} 100%{transform:scale(1)} }
    .checkbox.pop { animation: pop 0.3s ease; }
  </style>
