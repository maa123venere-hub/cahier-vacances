const TYPE = {
  lecon:   { color:"#16A34A", label:"Leçon + Exercices" },
  exo:     { color:"#2563EB", label:"Exercices" },
  dictee:  { color:"#D97706", label:"Dictée" },
  lecture: { color:"#7C3AED", label:"Lecture + Dictée" },
  redac:   { color:"#DC2626", label:"Rédaction + Dictée" },
  repos:   { color:"#0D9488", label:"Journée allégée 🎆" },
  controle:{ color:"#92400E", label:"Contrôle Final 🏆" },
};

// State
let currentWeek = 0;
let done = JSON.parse(localStorage.getItem('done2k26') || '{}');
let openDay = null;

function save() { localStorage.setItem('done2k26', JSON.stringify(done)); }

function totalDone() { return Object.values(done).filter(Boolean).length; }
const TOTAL = WEEKS.reduce((s,w)=>s+w.days.length,0);

function render() {
  const w = WEEKS[currentWeek];
  document.documentElement.style.setProperty('--week-color', w.color);

  // Progress
  const pct = Math.round((totalDone()/TOTAL)*100);
  document.getElementById('progressFill').style.width = pct+'%';
  document.getElementById('progressLabel').textContent = `${totalDone()} / ${TOTAL} journées terminées`;

  // Tabs
  document.getElementById('tabs').innerHTML = WEEKS.map((wk,i) => {
    const wd = wk.days.filter((_,j) => done[`${i}-${j}`]).length;
    return `<button class="tab ${i===currentWeek?'active':''}" style="--week-color:${wk.color}" onclick="goWeek(${i})">
      <span class="tab-emoji">${wk.emoji}</span>
      <span class="tab-num">S${wk.num}</span>
      <span class="tab-progress">${wd}/${wk.days.length}</span>
    </button>`;
  }).join('');

  // Banner
  const banner = document.getElementById('weekBanner');
  banner.style.background = w.light;
  banner.style.borderColor = w.color+'33';
  banner.innerHTML = `<div class="week-eyebrow" style="color:${w.color}">Semaine ${w.num} sur 8</div>
    <div class="week-title">${w.emoji} ${w.theme}</div>`;

  // Days
  document.getElementById('daysList').innerHTML = w.days.map((day,j) => {
    const key = `${currentWeek}-${j}`;
    const isDone = !!done[key];
    const isOpen = openDay === j;
    const t = TYPE[day.type] || TYPE.exo;
    return `
    <div class="day-card ${isDone?'done':''} ${isOpen?'open':''}" style="${isOpen?'border-color:'+w.color:''}">
      <div class="day-header" onclick="toggleDay(${j})">
        <div class="checkbox ${isDone?'checked':''}" style="${isDone?'background:'+w.color:''}" onclick="event.stopPropagation();toggleDone(${j})">
          ${isDone?'✓':''}
        </div>
        <div class="day-info">
          <div style="display:flex;align-items:center;gap:6px;flex-wrap:wrap;margin-bottom:3px">
            <span class="day-badge" style="background:${t.color}">${t.label}</span>
          </div>
          <div class="day-label ${isDone?'done-text':''}">${day.label}</div>
          <div class="day-lecon">${day.lecon}</div>
        </div>
        <div class="chevron ${isOpen?'open':''}">▼</div>
      </div>
      <div class="day-detail ${isOpen?'open':''}">
        <div class="detail-section">
          <div class="detail-label" style="color:${w.color}">📖 Ce que tu fais aujourd'hui</div>
          <div class="detail-box">${day.detail}</div>
        </div>
        <div class="detail-section">
          <div class="detail-label" style="color:${w.color}">✏️ Exercices à faire</div>
          <div class="detail-box">
            ${day.exercices.map(e=>`<div class="exo-row"><span class="exo-arrow">→</span>${e}</div>`).join('')}
          </div>
        </div>
        <div class="tip-box">
          <span class="tip-icon">💡</span>
          <span class="tip-text">${day.tip}</span>
        </div>
        <button class="done-btn" style="background:${isDone?'#E5E7EB':''+w.color};color:${isDone?'#6B7280':'white'}" onclick="toggleDone(${j})">
          ${isDone ? '↩ Marquer comme non fait' : '✓ Marquer cette journée comme faite'}
        </button>
      </div>
    </div>`;
  }).join('');

  // Nav
  document.getElementById('btnPrev').disabled = currentWeek === 0;
  document.getElementById('btnNext').disabled = currentWeek === WEEKS.length-1;
}

function goWeek(i) {
  currentWeek = i;
  openDay = null;
  render();
  window.scrollTo({top:0, behavior:'smooth'});
  // Scroll tab into view
  setTimeout(()=>{
    const tabs = document.querySelectorAll('.tab');
    if(tabs[i]) tabs[i].scrollIntoView({inline:'center', behavior:'smooth'});
  }, 50);
}

function changeWeek(d) {
  const next = currentWeek + d;
  if(next >= 0 && next < WEEKS.length) goWeek(next);
}

function toggleDay(j) {
  openDay = openDay === j ? null : j;
  render();
}

function toggleDone(j) {
  const key = `${currentWeek}-${j}`;
  done[key] = !done[key];
  save();
  render();
}

// Install banner
window.addEventListener('load', () => {
  const isIOS = /iphone|ipad|ipod/i.test(navigator.userAgent);
  const isStandalone = window.navigator.standalone;
  if(isIOS && !isStandalone) {
    document.getElementById('installBanner').style.display = 'flex';
  }
});

// PWA
if('serviceWorker' in navigator) {
  navigator.serviceWorker.register('sw.js').catch(()=>{});
}

render();
